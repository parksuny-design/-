                        <path d="M 75 40 L 75 80" />
                    </g>
                    <g font-family="sans-serif" font-size="10" font-weight="bold" text-anchor="middle">
                        <circle cx="40" cy="15" r="6" fill="#ef4444" /><text x="40" y="15" fill="white" dy=".35em">1</text>
                        <path d="M 50 25 L 50 50" stroke="#ef4444" stroke-width="3" fill="none" marker-end="url(#arrow)" />
                        <circle cx="15" cy="30" r="6" fill="#ef4444" /><text x="15" y="30" fill="white" dy=".35em">2</text>
                        <path d="M 25 45 L 25 80 L 55 80" stroke="#ef4444" stroke-width="3" stroke-linejoin="round" fill="none" marker-end="url(#arrow)" />
                        <circle cx="85" cy="30" r="6" fill="#ef4444" /><text x="85" y="30" fill="white" dy=".35em">3</text>
                        <path d="M 75 45 L 75 65" stroke="#ef4444" stroke-width="3" fill="none" marker-end="url(#arrow)" />
                    </g>
                </svg>
                <div>
                    <h2 class="text-3xl font-bold text-emerald-800 flex items-center justify-center md:justify-start gap-2">
                        뫼 산 (산 산)
                        <span class="bg-emerald-200 text-emerald-800 px-3 py-1 rounded-full text-lg shadow-sm">총 3획</span>
                    </h2>
                    <p class="text-xl mt-3 md:mt-2">뾰족뾰족한 <b>산봉우리 3개</b>가 솟아있는 모양을 그린 글자예요.</p>
                    <p class="text-md text-slate-500 mt-1">('뫼'는 '산'의 옛날 말이에요!)</p>
                </div>
            </div>
            <div class="flex flex-col gap-4 bg-white p-6 rounded-xl shadow-inner border border-emerald-100">
                <div class="text-slate-500 font-bold text-xl text-center">👇 빨간색 번호와 화살표를 따라 써보아요!</div>
                <div class="flex flex-wrap justify-center gap-4 md:gap-8 mt-2">
                    <div class="flex flex-col items-center">
                        <div class="relative w-24 h-24 md:w-32 md:h-32 border-4 border-slate-300 rounded-xl bg-white guide-cross touch-none overflow-hidden">
                            <div class="absolute inset-0 flex items-center justify-center text-6xl md:text-7xl text-slate-100 hanja-font z-0 select-none pointer-events-none">山</div>
                            <canvas id="canvas-山-1" width="128" height="128" class="absolute top-0 left-0 w-full h-full cursor-crosshair z-10"></canvas>
                        </div>
                        <button data-target="canvas-山-1" class="btn-clear mt-3 px-4 py-1.5 bg-red-400 text-white rounded-full text-sm font-bold shadow hover:bg-red-500 active:scale-95 transition-all">지우기 🧹</button>
                    </div>
                    <div class="flex flex-col items-center">
                        <div class="relative w-24 h-24 md:w-32 md:h-32 border-4 border-slate-300 rounded-xl bg-white guide-cross touch-none overflow-hidden">
                            <div class="absolute inset-0 flex items-center justify-center text-6xl md:text-7xl text-slate-100 hanja-font z-0 select-none pointer-events-none">山</div>
                            <canvas id="canvas-山-2" width="128" height="128" class="absolute top-0 left-0 w-full h-full cursor-crosshair z-10"></canvas>
                        </div>
                        <button data-target="canvas-山-2" class="btn-clear mt-3 px-4 py-1.5 bg-red-400 text-white rounded-full text-sm font-bold shadow hover:bg-red-500 active:scale-95 transition-all">지우기 🧹</button>
                    </div>
                    <div class="flex flex-col items-center">
                        <div class="relative w-24 h-24 md:w-32 md:h-32 border-4 border-slate-300 rounded-xl bg-white guide-cross touch-none overflow-hidden">
                            <div class="absolute inset-0 flex items-center justify-center text-6xl md:text-7xl text-slate-100 hanja-font z-0 select-none pointer-events-none">山</div>
                            <canvas id="canvas-山-3" width="128" height="128" class="absolute top-0 left-0 w-full h-full cursor-crosshair z-10"></canvas>
                        </div>
                        <button data-target="canvas-山-3" class="btn-clear mt-3 px-4 py-1.5 bg-red-400 text-white rounded-full text-sm font-bold shadow hover:bg-red-500 active:scale-95 transition-all">지우기 🧹</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 대화형 짝맞추기 퀴즈 -->
        <div class="border-4 border-dashed border-purple-300 rounded-3xl p-6 md:p-8 bg-purple-50 no-print">
            <h2 class="text-3xl text-center text-purple-700 font-bold mb-4">🎯 척척박사 짝맞추기 게임</h2>
            <p class="text-center text-xl mb-6">뜻을 먼저 누르고, 알맞은 한자를 찾아 눌러주세요!</p>
            
            <!-- 메시지 박스 -->
            <div id="quiz-msg" class="text-center text-xl font-bold text-red-500 h-8 mb-4 transition-all"></div>

            <div class="flex justify-around items-center text-2xl font-bold">
                <!-- 뜻 목록 (onclick 속성 제거 및 id 변경) -->
                <div class="flex flex-col gap-4 text-center w-5/12">
                    <div id="m-목" class="meaning-btn bg-white px-4 py-4 rounded-xl shadow border-4 border-slate-200 cursor-pointer transition-all hover:bg-yellow-100">나무 목</div>
                    <div id="m-일" class="meaning-btn bg-white px-4 py-4 rounded-xl shadow border-4 border-slate-200 cursor-pointer transition-all hover:bg-yellow-100">날 일</div>
                    <div id="m-산" class="meaning-btn bg-white px-4 py-4 rounded-xl shadow border-4 border-slate-200 cursor-pointer transition-all hover:bg-yellow-100">뫼 산</div>
                    <div id="m-수" class="meaning-btn bg-white px-4 py-4 rounded-xl shadow border-4 border-slate-200 cursor-pointer transition-all hover:bg-yellow-100">물 수</div>
                    <div id="m-월" class="meaning-btn bg-white px-4 py-4 rounded-xl shadow border-4 border-slate-200 cursor-pointer transition-all hover:bg-yellow-100">달 월</div>
                </div>
                
                <!-- 한자 목록 (onclick 속성 제거 및 id 변경) -->
                <div class="flex flex-col gap-4 text-center hanja-font text-4xl w-5/12">
                    <div id="h-산" class="hanja-btn bg-white px-4 py-3 rounded-xl shadow border-4 border-slate-200 cursor-pointer transition-all hover:bg-blue-50">山</div>
                    <div id="h-월" class="hanja-btn bg-white px-4 py-3 rounded-xl shadow border-4 border-slate-200 cursor-pointer transition-all hover:bg-blue-50">月</div>
                    <div id="h-목" class="hanja-btn bg-white px-4 py-3 rounded-xl shadow border-4 border-slate-200 cursor-pointer transition-all hover:bg-blue-50">木</div>
                    <div id="h-일" class="hanja-btn bg-white px-4 py-3 rounded-xl shadow border-4 border-slate-200 cursor-pointer transition-all hover:bg-blue-50">日</div>
                    <div id="h-수" class="hanja-btn bg-white px-4 py-3 rounded-xl shadow border-4 border-slate-200 cursor-pointer transition-all hover:bg-blue-50">水</div>
                </div>
            </div>
            
            <div id="success-msg" class="mt-8 text-center text-3xl text-purple-600 font-bold hidden opacity-0 transition-opacity duration-500">
                🎉 참 잘했어요! 선생님 도장 쾅! 💮 🎉
            </div>
        </div>

    </div>

    <script>
        // HTML 문서 구조가 모두 불러와진 후 스크립트를 실행합니다. (오류 방지)
        document.addEventListener('DOMContentLoaded', () => {
            
            // ==========================================
            // 1. 캔버스 그리기 및 지우기 로직
            // ==========================================
            const hanjas = ['日', '月', '木', '水', '山'];
            
            hanjas.forEach(h => {
                for (let i = 1; i <= 3; i++) {
                    const canvas = document.getElementById(`canvas-${h}-${i}`);
                    if(!canvas) continue;
                    const ctx = canvas.getContext('2d');
                    ctx.lineCap = 'round';
                    ctx.lineJoin = 'round';
                    ctx.lineWidth = 10; 
                    ctx.strokeStyle = '#334155'; 

                    let isDrawing = false;
                    let lastX = 0;
                    let lastY = 0;

                    function getPos(e) {
                        const rect = canvas.getBoundingClientRect();
                        const clientX = e.touches ? e.touches[0].clientX : e.clientX;
                        const clientY = e.touches ? e.touches[0].clientY : e.clientY;
                        
                        const scaleX = canvas.width / rect.width;
                        const scaleY = canvas.height / rect.height;

                        return {
                            x: (clientX - rect.left) * scaleX,
                            y: (clientY - rect.top) * scaleY
                        };
                    }

                    function startDraw(e) {
                        e.preventDefault(); 
                        isDrawing = true;
                        const pos = getPos(e);
                        lastX = pos.x;
                        lastY = pos.y;
                    }

                    function draw(e) {
                        if (!isDrawing) return;
                        e.preventDefault(); 
                        const pos = getPos(e);
                        ctx.beginPath();
                        ctx.moveTo(lastX, lastY);
                        ctx.lineTo(pos.x, pos.y);
                        ctx.stroke();
                        lastX = pos.x;
                        lastY = pos.y;
                    }

                    function endDraw(e) {
                        if(e && e.type !== 'mouseout') e.preventDefault();
                        isDrawing = false;
                    }

                    canvas.addEventListener('mousedown', startDraw);
                    canvas.addEventListener('mousemove', draw);
                    canvas.addEventListener('mouseup', endDraw);
                    canvas.addEventListener('mouseout', endDraw);

                    canvas.addEventListener('touchstart', startDraw, {passive: false});
                    canvas.addEventListener('touchmove', draw, {passive: false});
                    canvas.addEventListener('touchend', endDraw);
                    canvas.addEventListener('touchcancel', endDraw);
                }
            });

            // "지우기" 버튼 이벤트 연결
            document.querySelectorAll('.btn-clear').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const targetId = e.target.getAttribute('data-target');
                    const canvas = document.getElementById(targetId);
                    if (canvas) {
                        const ctx = canvas.getContext('2d');
                        ctx.clearRect(0, 0, canvas.width, canvas.height);
                    }
                });
            });


            // ==========================================
            // 2. 대화형 짝맞추기 퀴즈 로직
            // ==========================================
            let selectedMeaning = null;
            let matchedCount = 0;
            const msgBox = document.getElementById('quiz-msg');
            const successMsg = document.getElementById('success-msg');
            
            const matches = {
                'm-목': 'h-목', 
                'm-일': 'h-일', 
                'm-산': 'h-산', 
                'm-수': 'h-수', 
                'm-월': 'h-월'
            };

            function showMessage(msg, type='error') {
                msgBox.textContent = msg;
                msgBox.className = `text-center text-xl font-bold h-8 mb-4 transition-all ${type === 'error' ? 'text-red-500' : 'text-blue-500'}`;
                setTimeout(() => { msgBox.textContent = ''; }, 2000);
            }

            // '뜻' 버튼을 눌렀을 때
            document.querySelectorAll('.meaning-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const targetBtn = e.currentTarget;
                    if (targetBtn.classList.contains('bg-green-200')) return; // 이미 정답 맞춘 버튼은 무시

                    // 다른 선택된 버튼들 초기화
                    document.querySelectorAll('.meaning-btn').forEach(b => {
                        if(!b.classList.contains('bg-green-200')) {
                            b.classList.remove('bg-yellow-300', 'scale-105', 'border-yellow-500');
                            b.classList.add('bg-white', 'border-slate-200');
                        }
                    });

                    selectedMeaning = targetBtn.id;
                    targetBtn.classList.remove('bg-white', 'border-slate-200');
                    targetBtn.classList.add('bg-yellow-300', 'scale-105', 'border-yellow-500');
                    
                    msgBox.textContent = '이제 알맞은 한자를 찾아보세요!';
                    msgBox.className = 'text-center text-xl font-bold text-blue-500 h-8 mb-4';
                });
            });

            // '한자' 버튼을 눌렀을 때
            document.querySelectorAll('.hanja-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const targetBtn = e.currentTarget;
                    const id = targetBtn.id;
                    
                    if (!selectedMeaning) {
                        showMessage('앗! 왼쪽에서 뜻을 먼저 선택해주세요!', 'error');
                        return;
                    }
                    if (targetBtn.classList.contains('bg-green-200')) return;

                    if (matches[selectedMeaning] === id) {
                        // 정답일 때
                        const mEl = document.getElementById(selectedMeaning);
                        const hEl = targetBtn;
                        
                        mEl.classList.remove('bg-yellow-300', 'border-yellow-500');
                        mEl.classList.add('bg-green-200', 'border-green-500', 'text-green-800');
                        
                        hEl.classList.remove('bg-white', 'border-slate-200');
                        hEl.classList.add('bg-green-200', 'border-green-500', 'text-green-800', 'scale-110');

                        selectedMeaning = null;
                        matchedCount++;
                        msgBox.textContent = '딩동댕! 정답이에요!';
                        msgBox.className = 'text-center text-xl font-bold text-green-500 h-8 mb-4';

                        if (matchedCount === 5) {
                            msgBox.textContent = '';
                            successMsg.classList.remove('hidden');
                            setTimeout(() => { successMsg.classList.remove('opacity-0'); }, 50);
                        }
                    } else {
                        // 오답일 때
                        showMessage('틀렸어요! 다시 한 번 생각해보세요.', 'error');
                        targetBtn.classList.add('bg-red-200', 'border-red-500', 'animate-pulse');
                        setTimeout(() => {
                            targetBtn.classList.remove('bg-red-200', 'border-red-500', 'animate-pulse');
                        }, 600);
                    }
                });
            });


            // ==========================================
            // 3. 상단 다운로드 및 인쇄 버튼 로직
            // ==========================================
            document.getElementById('btn-print').addEventListener('click', () => {
                window.print();
            });

            document.getElementById('btn-download').addEventListener('click', () => {
                const htmlContent = "<!DOCTYPE html>\n" + document.documentElement.outerHTML;
                const blob = new Blob([htmlContent], { type: 'text/html;charset=utf-8' });
                const url = URL.createObjectURL(blob);
                
                const a = document.createElement('a');
                a.href = url;
                a.download = 'game.html';
                
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
            });

        }); // DOMContentLoaded 종료
    </script>
</body>
