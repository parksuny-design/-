        <!-- 한자 5: 뫼 산 -->
        <div class="mb-12 bg-emerald-50 p-6 md:p-8 rounded-2xl border-2 border-emerald-200">
            <div class="flex flex-col md:flex-row items-center gap-6 mb-6 text-center md:text-left">
