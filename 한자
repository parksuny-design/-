    <style>
        @import url('https://fonts.googleapis.com/css2?family=Jua&family=Nanum+Pen+Script&display=swap');

        body {
            font-family: 'Jua', sans-serif;
            background-color: #f8fafc;
            /* 모바일에서 텍스트 선택 방지 */
            -webkit-user-select: none;
            user-select: none;
        }

        .hanja-font {
            font-family: 'Batang', 'Malgun Gothic', serif; 
        }

        /* 십자선 (가이드라인) 배경 */
        .guide-cross {
            position: relative;
        }
        .guide-cross::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0;
            right: 0;
            border-top: 2px dashed #e2e8f0;
            z-index: 0;
        }
        .guide-cross::after {
            content: '';
            position: absolute;
            top: 0;
            bottom: 0;
            left: 50%;
            border-left: 2px dashed #e2e8f0;
            z-index: 0;
        }

        @media print {
            .no-print { display: none !important; }
            body { background-color: white; }
            .container { box-shadow: none !important; border: none !important; padding: 0 !important; }
        }
    </style>
